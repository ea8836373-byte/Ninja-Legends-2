local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Best Hub | Ninja Legends 2",
   LoadingTitle = "Best Hub Creations",
   LoadingSubtitle = "by @rexbgod",
   ConfigurationSaving = {
      Enabled = false
   },
   KeySystem = false
})

local Player = game.Players.LocalPlayer
local SelectedIsland = ""

-- --- CONFIGURAZIONE COORDINATE ESATTE IN ORDINE ---
local IslandCoordinates = {
    { Name = "Planet Zephyr", Pos = Vector3.new(1.16, 1467.45, 142.06) },
    { Name = "Infernal Planet", Pos = Vector3.new(1.16, 3057.55, 142.06) },
    { Name = "Planet Omega", Pos = Vector3.new(1.16, 4681.55, 142.06) },
    { Name = "Elements Planet", Pos = Vector3.new(63.18, 6311.65, 101.07) },
    { Name = "Planet of Chaos", Pos = Vector3.new(1.16, 8632.05, 142.06) }
}

-- --- FUNZIONE TELETRASPORTO DIRETTO ---
local function DirectTeleport(pos)
    if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
        Player.Character.HumanoidRootPart.CFrame = CFrame.new(pos)
    end
end

-- --- FUNZIONE DI PROSSIMITÀ ISTANTANEA (NO TELEPORT PER SHOP/SELL) ---
local function FireProximity(targetPos)
    if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
        local currentCFrame = Player.Character.HumanoidRootPart.CFrame
        Player.Character.HumanoidRootPart.CFrame = CFrame.new(targetPos)
        task.wait(0.05)
        Player.Character.HumanoidRootPart.CFrame = currentCFrame
    end
end

-- --- FUNZIONE AUTO-EQUIP ANCHE DOPO LA MORTE ---
local function EnsureWeaponEquipped()
    local char = Player.Character
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    
    if char and humanoid and humanoid.Health > 0 then
        local tool = Player.Backpack:FindFirstChildOfClass("Tool") or char:FindFirstChildOfClass("Tool")
        if tool and tool.Parent ~= char then
            humanoid:EquipTool(tool)
        end
    end
end

--------------------------------------------------------------------------------
-- MAIN TAB
--------------------------------------------------------------------------------
local MainTab = Window:CreateTab("Main", "dumbbell")

MainTab:CreateSection("Training & Progression")

-- Auto Swing
MainTab:CreateToggle({
   Name = "Auto Swing",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoSwing = Value
      task.spawn(function()
         while _G.AutoSwing do
            EnsureWeaponEquipped()
            local event = Player:FindFirstChild("saberEvent")
            if event then
               event:FireServer("swingBlade")
            end
            task.wait(0.1)
         end
      end)
   end,
})

-- Auto Upgrade Swords
MainTab:CreateToggle({
   Name = "Auto Upgrade Swords",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoSwords = Value
      task.spawn(function()
         while _G.AutoSwords do
            local event = Player:FindFirstChild("saberEvent")
            if event then
               event:FireServer("buyAllItems", { whichPlanet = "Ground", whichItems = "Swords" })
            end
            task.wait(2)
         end
      end)
   end,
})

-- Auto Upgrade Crystals / Elements
MainTab:CreateToggle({
   Name = "Auto Upgrade Crystals / Elements",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoCrystals = Value
      task.spawn(function()
         while _G.AutoCrystals do
            local event = Player:FindFirstChild("saberEvent")
            if event then
               event:FireServer("buyAllItems", { whichPlanet = "Ground", whichItems = "Crystals" })
            end
            task.wait(2)
         end
      end)
   end,
})

MainTab:CreateSection("Utilities")

-- Infinite Jumps
MainTab:CreateToggle({
   Name = "Infinite Jumps",
   CurrentValue = false,
   Callback = function(Value)
      _G.InfJumps = Value
      game:GetService("UserInputService").JumpRequest:Connect(function()
         if _G.InfJumps and Player.Character and Player.Character:FindFirstChildOfClass("Humanoid") then
            Player.Character:FindFirstChildOfClass("Humanoid"):ChangeState("Jumping")
         end
      end)
   end,
})

-- Sell
MainTab:CreateButton({
   Name = "Sell",
   Callback = function()
      FireProximity(Vector3.new(-89.70, 113.22, 131.84))
   end,
})

-- Shop
MainTab:CreateButton({
   Name = "Shop",
   Callback = function()
      FireProximity(Vector3.new(-1.86, 113.75, 94.90))
   end,
})

