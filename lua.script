--------------------------------------------------------------------------------
-- ISLANDS TAB
--------------------------------------------------------------------------------
local IslandsTab = Window:CreateTab("Islands", "map")

IslandsTab:CreateSection("World Travel")

-- Menu a tendina con i 5 nomi
IslandsTab:CreateDropdown({
   Name = "Islands list",
   Options = {"Planet Zephyr", "Infernal Planet", "Planet Omega", "Elements Planet", "Planet of Chaos"},
   CurrentOption = "",
   MultipleOptions = false,
   Callback = function(Option)
       SelectedIsland = Option
   end,
})

-- Tasto TP per l'isola selezionata
IslandsTab:CreateButton({
   Name = "TP",
   Callback = function()
       if SelectedIsland ~= "" then
           for _, island in ipairs(IslandCoordinates) do
               if island.Name == SelectedIsland then
                   DirectTeleport(island.Pos)
                   Rayfield:Notify({Title = "Best Hub", Content = "Teletrasportato a: " .. SelectedIsland, Duration = 2})
                   break
               end
           end
       else
           Rayfield:Notify({Title = "Errore", Content = "Scegli prima un'isola dalla lista!", Duration = 3})
       end
   end,
})

-- Tasto Unlock all (fa il giro di tutte e 5 le nuove coordinate)
IslandsTab:CreateButton({
   Name = "Unlock all",
   Callback = function()
       task.spawn(function()
           for _, island in ipairs(IslandCoordinates) do
               Rayfield:Notify({Title = "Best Hub", Content = "Sbloccando " .. island.Name .. "...", Duration = 1.2})
               DirectTeleport(island.Pos)
               task.wait(1.5)
           end
           Rayfield:Notify({Title = "Best Hub", Content = "Tutti e 5 i pianeti sono stati sbloccati con successo!", Duration = 3})
       end)
   end,
})

